# Скопіюйте цей файл у .env і заповніть реальними значеннями.
# .env НІКОЛИ не комітиться в git (див. .gitignore) — Завдання 24.

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

EXCHANGE_NAME=bybit
BYBIT_REST_URL=https://api.bybit.com
BYBIT_WS_URL=wss://stream.bybit.com/v5/public/spot

# Локально SQLite за замовчуванням; для PostgreSQL розкоментуйте:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/crypto_bot
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=replace_with_a_long_random_string

# Web Push (Завдання 15) — генерація: python scripts/generate_vapid.py
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
